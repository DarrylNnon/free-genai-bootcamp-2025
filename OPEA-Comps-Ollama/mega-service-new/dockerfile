# Use an official, slim Python base image
FROM python:3.11-slim

# Set environment variables to prevent Python from writing .pyc files and buffering stdout
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Set working directory inside container
WORKDIR /app

# Install system dependencies (if needed)
# RUN apt-get update && apt-get install -y build-essential

# Copy only requirements first for better layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy the rest of the application code
COPY . .

RUN chmod +x /app/bin/message.py

# Expose the port your app runs on (match the `self.port` in code)
EXPOSE 8888

# Run the service using Python directly (could also use uvicorn/gunicorn if async + FastAPI)
CMD ["python", "main.py"]
